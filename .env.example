# Works around a Metro SDK 56+ guard that throws if expo-router and @react-navigation/core are
# both resolvable in node_modules. expo-router ships as an internal transitive dependency of
# expo's own CLI regardless of whether the app uses it, so this is a false positive — the app
# itself has no expo-router imports (see README: "React Navigation over expo-router").
EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1
